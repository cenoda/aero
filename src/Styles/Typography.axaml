<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Phase 8.9 Design System: Typography Scale
       Font Family: Inter (loaded via Avalonia.Fonts.Inter package) -->
  <x:Double x:Key="FontSize.StatusBar">11</x:Double>
  <x:Double x:Key="FontSize.UILabel">12</x:Double>
  <x:Double x:Key="FontSize.Body">13</x:Double>
  <x:Double x:Key="FontSize.TabTitle">14</x:Double>
  <x:Double x:Key="FontSize.Heading">16</x:Double>

  <FontWeight x:Key="FontWeight.Normal">Normal</FontWeight>
  <FontWeight x:Key="FontWeight.SemiBold">DemiBold</FontWeight>
  <FontWeight x:Key="FontWeight.Bold">Bold</FontWeight>
</ResourceDictionary>
