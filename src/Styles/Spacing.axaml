<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Phase 8.9 Design System: Spacing Scale (4px grid base) -->
  <x:Double x:Key="Spacing.xxs">4</x:Double>
  <x:Double x:Key="Spacing.xs">8</x:Double>
  <x:Double x:Key="Spacing.sm">12</x:Double>
  <x:Double x:Key="Spacing.md">16</x:Double>
  <x:Double x:Key="Spacing.lg">24</x:Double>
  <x:Double x:Key="Spacing.xl">32</x:Double>

  <!-- Semantic aliases -->
  <x:Double x:Key="Button.Padding">8</x:Double>
  <x:Double x:Key="Button.MinHeight">32</x:Double>
  <x:Double x:Key="Panel.Padding">16</x:Double>
  <x:Double x:Key="Section.Gap">12</x:Double>
  <x:Double x:Key="List.Item.Height">32</x:Double>
  <x:Double x:Key="Tab.Padding">8,4</x:Double>
  <x:Double x:Key="StatusBar.Padding">8,4</x:Double>
</ResourceDictionary>
