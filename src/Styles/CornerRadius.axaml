<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Phase 8.9 Design System: Corner Radius (Apple/Rider inspired)
       Values stored as CornerRadius; applied via Style setters on each control -->
  <CornerRadius x:Key="Radius.Button">6</CornerRadius>
  <CornerRadius x:Key="Radius.Input">6</CornerRadius>
  <CornerRadius x:Key="Radius.Panel">8</CornerRadius>
  <CornerRadius x:Key="Radius.Dialog">10</CornerRadius>
  <CornerRadius x:Key="Radius.Popup">10</CornerRadius>
  <CornerRadius x:Key="Radius.Tab">4</CornerRadius>
  <CornerRadius x:Key="Radius.ScrollbarThumb">4</CornerRadius>
</ResourceDictionary>
