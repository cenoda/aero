<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Phase 8.9 Design System: Corner Radius (Apple/Rider inspired)
       Values stored as x:Double; applied via Style setters on each control -->
  <x:Double x:Key="Radius.Button">6</x:Double>
  <x:Double x:Key="Radius.Input">6</x:Double>
  <x:Double x:Key="Radius.Panel">8</x:Double>
  <x:Double x:Key="Radius.Dialog">10</x:Double>
  <x:Double x:Key="Radius.Popup">10</x:Double>
  <x:Double x:Key="Radius.Tab">4</x:Double>
  <x:Double x:Key="Radius.ScrollbarThumb">4</x:Double>
</ResourceDictionary>
