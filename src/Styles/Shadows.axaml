<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Phase 8.9 Design System: Shadow System (layered depth) -->
  <BoxShadow x:Key="Shadow.Subtle">0 1 2 0 #14000000</BoxShadow>
  <BoxShadow x:Key="Shadow.Medium">0 4 12 0 #1F000000</BoxShadow>
  <BoxShadow x:Key="Shadow.Popup">0 8 24 0 #29000000</BoxShadow>
</ResourceDictionary>
