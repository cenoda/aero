<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Aero.Views"
             xmlns:vm="using:Aero.ViewModels"
             x:Class="Aero.Views.GitGraphView"
             x:DataType="vm:GitGraphViewModel">
  <Grid ColumnDefinitions="*,Auto">
    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
      <views:GitGraphControl x:Name="GraphControl"
                             Nodes="{Binding Nodes}"
                             Lanes="{Binding Lanes}"
                             SelectedCommit="{Binding SelectedCommit}"
                             Width="{Binding TotalWidth}"
                             Height="{Binding TotalHeight}" />
    </ScrollViewer>
  </Grid>
</UserControl>
