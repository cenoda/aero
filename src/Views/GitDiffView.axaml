<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="https://github.com/avaloniaui/avaloniaui"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aero.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Aero.Views.GitDiffView"
             x:DataType="vm:GitDiffViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <ItemsControl ItemsSource="{Binding Lines}">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:GitDiffLineViewModel">
          <Border Background="{Binding LineBackground}" Padding="0,1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*">
              <!-- Gutter (+/-/space) -->
              <TextBlock Grid.Column="0" Text="{Binding Gutter}" Width="20"
                        FontFamily="Consolas, Menlo, monospace" FontSize="12"
                        FontWeight="Bold" Foreground="{Binding LineBackground}"/>
              <!-- Old line number -->
              <TextBlock Grid.Column="1" Text="{Binding OldLineNumber}" Width="40"
                        FontFamily="Consolas, Menlo, monospace" FontSize="12"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        HorizontalAlignment="Right" Margin="0,0,4,0"/>
              <!-- New line number -->
              <TextBlock Grid.Column="2" Text="{Binding NewLineNumber}" Width="40"
                        FontFamily="Consolas, Menlo, monospace" FontSize="12"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        HorizontalAlignment="Right" Margin="0,0,8,0"/>
              <!-- Content -->
              <TextBlock Grid.Column="3" Text="{Binding Content}"
                        FontFamily="Consolas, Menlo, monospace" FontSize="12"
                        FontWeight="Bold"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </ScrollViewer>
</UserControl>