<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="https://github.com/avaloniaui/avaloniaui"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aero.ViewModels"
             xmlns:lang="using:Aero.Languages"
             x:Class="Aero.Views.ProblemsView"
             x:DataType="vm:ProblemsViewModel">

    <Border Background="{DynamicResource panel.background}"
            BorderBrush="{DynamicResource panel.border}"
            BorderThickness="0,1,0,0">
        <!-- ISSUE-013 fix: add Background to DockPanel -->
        <DockPanel Background="{DynamicResource panel.background}">
            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource panel.sectionBackground}"
                    BorderBrush="{DynamicResource panel.border}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <TextBlock Text="Problems"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Empty state (Phase 8.1 M5.2: enhanced with icon) -->
            <StackPanel IsVisible="{Binding !Diagnostics.Count}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Spacing="8">
                <PathIcon Data="{StaticResource Icon.CheckCircle}"
                        Width="40" Height="40"
                        Foreground="{DynamicResource panel.emptyStateForeground}"
                        HorizontalAlignment="Center"/>
                <TextBlock Text="No problems detected"
                          Foreground="{DynamicResource panel.emptyStateForeground}"
                          FontWeight="SemiBold"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Errors and warnings will appear here"
                          Foreground="{DynamicResource panel.emptyStateForeground}"
                          FontSize="11"
                          HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Diagnostics list -->
            <ListBox ItemsSource="{Binding Diagnostics}"
                    IsVisible="{Binding Diagnostics.Count}"
                    Background="Transparent"
                    BorderThickness="0"
                    x:Name="DiagnosticsList">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="lang:Diagnostic">
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Severity icon -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SeverityIcon}"
                                       Foreground="{Binding SeverityColor}"
                                       FontWeight="Bold"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>

                            <!-- Message and location -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Message}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding FileName}"
                                           FontSize="11"
                                           Opacity="0.7"/>
                            </StackPanel>

                            <!-- Line:Col -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LocationText}"
                                       FontSize="11"
                                       Opacity="0.7"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>