<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aero.ViewModels"
             x:Class="Aero.Views.FindReplaceOverlay"
             x:DataType="vm:FindReplaceViewModel">

    <Border Background="#E8E8E8"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Padding="8"
            CornerRadius="4">
        <StackPanel Spacing="8">
            <!-- Find row -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Find:" 
                         VerticalAlignment="Center"
                         Width="50"/>
                <TextBox Text="{Binding SearchText}"
                         Width="250"
                         Watermark="Search text..."/>
            </StackPanel>

            <!-- Replace row -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Replace:" 
                         VerticalAlignment="Center"
                         Width="50"/>
                <TextBox Text="{Binding ReplaceText}"
                         Width="250"
                         Watermark="Replace with..."/>
            </StackPanel>

            <!-- Options -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox IsChecked="{Binding CaseSensitive}"
                        Content="Match case"/>
                <CheckBox IsChecked="{Binding WholeWord}"
                        Content="Whole word"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Find Next"
                        Command="{Binding FindNextCommand}"/>
                <Button Content="Replace"
                        Command="{Binding ReplaceCommand}"/>
                <Button Content="Replace All"
                        Command="{Binding ReplaceAllCommand}"/>
                <Button Content="Close"
                        Command="{Binding CloseCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>

</UserControl>
