<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aero.ViewModels"
             x:Class="Aero.Views.FindReplaceOverlay"
             x:DataType="vm:FindReplaceViewModel">

    <!-- Keyboard shortcuts: Enter=Find Next, Escape=Close -->
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding FindNextCommand}"/>
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommand}"/>
    </UserControl.KeyBindings>

    <Border Background="#E8E8E8"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Padding="8"
            CornerRadius="4">
        <StackPanel Spacing="8">
            <!-- Find row -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Find:" 
                         VerticalAlignment="Center"
                         Width="50"/>
                <TextBox x:Name="SearchTextBox"
                         Text="{Binding SearchText}"
                         Width="250"
                         Watermark="Search text..."
                         TabIndex="0"/>
            </StackPanel>

            <!-- Replace row -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Replace:" 
                         VerticalAlignment="Center"
                         Width="50"/>
                <TextBox x:Name="ReplaceTextBox"
                         Text="{Binding ReplaceText}"
                         Width="250"
                         Watermark="Replace with..."
                         TabIndex="1"/>
            </StackPanel>

            <!-- Options -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox IsChecked="{Binding CaseSensitive}"
                        Content="Match case"
                        TabIndex="2"/>
                <CheckBox IsChecked="{Binding WholeWord}"
                        Content="Whole word"
                        TabIndex="3"/>
            </StackPanel>

            <!-- Buttons - Find Next is default for Enter key -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="FindNextButton"
                        Content="Find Next"
                        Command="{Binding FindNextCommand}"
                        IsDefault="True"
                        TabIndex="4"/>
                <Button Content="Replace"
                        Command="{Binding ReplaceCommand}"
                        TabIndex="5"/>
                <Button Content="Replace All"
                        Command="{Binding ReplaceAllCommand}"
                        TabIndex="6"/>
                <Button Content="Close"
                        Command="{Binding CloseCommand}"
                        TabIndex="7"/>
            </StackPanel>
        </StackPanel>
    </Border>

</UserControl>
