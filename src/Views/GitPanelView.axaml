<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="https://github.com/avaloniaui/avaloniaui"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aero.ViewModels"
             xmlns:git="using:Aero.Models.Git"
             xmlns:views="using:Aero.Views"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
             x:Class="Aero.Views.GitPanelView"
             x:DataType="vm:GitViewModel">
  <Grid RowDefinitions="Auto,*,Auto">
    
    <!-- Header -->
    <Border Grid.Row="0"
            Classes="panel-border"
            Background="{DynamicResource git.panel.headerBackground}"
            BorderBrush="{DynamicResource git.panel.sectionBorder}"
            Padding="10,8">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="Git" FontWeight="Bold" FontSize="14"/>
        <TextBlock Text="•" Foreground="{DynamicResource panel.headerForeground}"/>
        <TextBlock Text="{Binding CurrentBranch}" FontSize="12"
                   Foreground="{DynamicResource git.branchForeground}"
                   FontWeight="SemiBold"/>
      </StackPanel>
    </Border>

    <!-- Empty state (Phase 8.1 M5.4: enhanced with icon) -->
    <StackPanel Grid.Row="1"
                IsVisible="{Binding !HasGitRepository}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <PathIcon Data="{StaticResource Icon.GitBranch}"
                Width="40" Height="40"
                Foreground="{DynamicResource panel.emptyStateForeground}"
                HorizontalAlignment="Center"/>
      <TextBlock Text="No repository"
                Foreground="{DynamicResource panel.emptyStateForeground}"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"/>
      <TextBlock Text="Open a folder with a Git repository"
                Foreground="{DynamicResource panel.emptyStateForeground}"
                FontSize="11"
                HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Tab Control: Changes | Graph -->
    <TabControl Grid.Row="1"
               IsVisible="{Binding HasGitRepository}">
      <TabItem Header="Changes">
        <Grid ColumnDefinitions="*,*" Margin="6" ColumnSpacing="6">
      
      <!-- Staged Changes (Left) -->
      <Border Grid.Column="0"
              Classes="panel-border"
              Background="{DynamicResource panel.sectionBackground}"
              BorderBrush="{DynamicResource git.panel.sectionBorder}"
              Margin="0">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="{DynamicResource git.panel.sectionHeaderBackground}" Padding="8,6">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
              <TextBlock Grid.Column="0" Text="Staged" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Classes="git-compact-action" Content="Unstage All" Command="{Binding UnstageAllCommand}"/>
            </Grid>
          </Border>
          <ScrollViewer Grid.Row="1" Margin="4">
            <ItemsControl ItemsSource="{Binding StagedChanges}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:GitFileStatusViewModel">
                  <Border Classes="git-file-row"
                          Background="{DynamicResource git.panel.rowBackground}"
                          Margin="0,1">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                      <Button Grid.Column="0" Classes="git-icon-button"
                              Command="{Binding $parent[UserControl].DataContext.UnstageFileCommand}"
                              CommandParameter="{Binding FilePath}"
                              Content="←"/>
                      <Button Grid.Column="1"
                              Command="{Binding $parent[UserControl].DataContext.DiffCommand}"
                              CommandParameter="{Binding FilePath}"
                              Classes="git-file-button">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding StatusIcon}" Width="16" Foreground="{DynamicResource git.stagedForeground}"/>
                          <TextBlock Text="{Binding DisplayPath}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Unstaged Changes (Right) -->
      <Border Grid.Column="1"
              Classes="panel-border"
              Background="{DynamicResource panel.sectionBackground}"
              BorderBrush="{DynamicResource git.panel.sectionBorder}"
              Margin="0">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="{DynamicResource git.panel.sectionHeaderBackground}" Padding="8,6">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
              <TextBlock Grid.Column="0" Text="Unstaged" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Classes="git-compact-action" Content="Stage All" Command="{Binding StageAllCommand}"/>
            </Grid>
          </Border>
          <ScrollViewer Grid.Row="1" Margin="4">
            <ItemsControl ItemsSource="{Binding UnstagedChanges}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:GitFileStatusViewModel">
                  <Border Classes="git-file-row"
                          Background="{DynamicResource git.panel.rowBackground}"
                          Margin="0,1">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                      <Button Grid.Column="0" Classes="git-icon-button"
                              Command="{Binding $parent[UserControl].DataContext.StageFileCommand}"
                              CommandParameter="{Binding FilePath}"
                              Content="→"/>
                      <Button Grid.Column="1"
                              Command="{Binding $parent[UserControl].DataContext.DiffCommand}"
                              CommandParameter="{Binding FilePath}"
                              Classes="git-file-button">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding StatusIcon}" Width="16" Foreground="{DynamicResource git.modifiedForeground}"/>
                          <TextBlock Text="{Binding DisplayPath}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
      </TabItem>
      <TabItem Header="Graph">
        <views:GitGraphView DataContext="{Binding GitGraphViewModel}" />
      </TabItem>
    </TabControl>

    <!-- Commit Box -->
    <Border Grid.Row="2"
            Classes="panel-border"
            Background="{DynamicResource git.panel.headerBackground}"
            BorderBrush="{DynamicResource git.panel.sectionBorder}"
            Padding="10,8">
      <StackPanel Spacing="6">
        <TextBox x:Name="CommitMessageBox"
                Text="{Binding CommitMessage, Mode=TwoWay}"
                Watermark="Commit message..."
                AcceptsReturn="False"
                Height="32"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
          <Button Grid.Column="0" Content="Commit" Command="{Binding CommitCommand}"
                  HorizontalAlignment="Stretch"/>
          <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}"/>
        </Grid>
        <!-- Branch Checkout -->
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0" ColumnSpacing="6">
          <TextBlock Grid.Column="0" Text="Branch:" VerticalAlignment="Center"/>
          <ComboBox Grid.Column="1" x:Name="BranchSelector"
                  ItemsSource="{Binding Branches}"
                  HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="git:GitBranchInfo">
                <TextBlock Text="{Binding Name}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Grid.Column="2" Content="Checkout" Command="{Binding CheckoutBranchCommand}"
                  CommandParameter="{Binding #BranchSelector.SelectedItem.Name}"
                  Padding="10,4"/>
        </Grid>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
