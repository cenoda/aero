<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="https://github.com/avaloniaui/avaloniaui"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aero.ViewModels"
             x:Class="Aero.Views.FileExplorerView"
             x:DataType="vm:FileExplorerViewModel">

    <Border Background="#FAFAFA"
            BorderBrush="#CCCCCC"
            BorderThickness="0,0,1,0">
        <DockPanel>
            <!-- Header: title + refresh button.
                 Icons paused — see docs/phases/phase-2/TOFIX.md R3.1. Will
                 add Material.Icons back when the icon-library decision lands. -->
            <Border DockPanel.Dock="Top"
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="File Explorer"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="&#x27F3;"
                            Command="{Binding RefreshCommand}"
                            ToolTip.Tip="Refresh (re-enumerate)"
                            Padding="6,2"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"/>
                </Grid>
            </Border>

            <!-- Status / hint row -->
            <Border DockPanel.Dock="Bottom"
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,1,0,0"
                    Padding="8,4">
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- Empty-state hint -->
            <TextBlock Text="No folder open. Use File → Open Folder (Ctrl+Shift+O)."
                       IsVisible="{Binding !HasRootPath}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="12"
                       Opacity="0.5"/>

            <!-- Loading indicator (thin progress bar at the top of the tree) -->
            <ProgressBar DockPanel.Dock="Top"
                         IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}"
                         Height="2"
                         Foreground="#0078D4"
                         Margin="0,2,0,0"/>

            <!-- The tree. ItemsSource binds the root collection; TreeDataTemplate
                 recurses into Children. A simple glyph prefix replaces icons
                 for now (see TOFIX R3.1). -->
            <TreeView x:Name="ExplorerTree"
                      ItemsSource="{Binding RootNodes}"
                      SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                      Padding="4">
                <TreeView.Styles>
                    <!-- Bind container expansion to the node VM so keyboard
                         Enter can toggle directories and VM state stays in sync
                         with user-driven expand/collapse. -->
                    <Style Selector="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate x:DataType="vm:FileExplorerNodeViewModel"
                                      ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="New File"
                                              Command="{Binding Owner.NewFileCommand}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="New Folder"
                                              Command="{Binding Owner.NewFolderCommand}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Rename"
                                              Command="{Binding Owner.RenameCommand}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Delete"
                                              Command="{Binding Owner.DeleteCommand}"
                                              CommandParameter="{Binding}"/>
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <TextBlock Text="{Binding Glyph}"
                                       Width="14"
                                       Opacity="0.6"
                                       VerticalAlignment="Center"
                                       FontFamily="Consolas, Courier New, monospace"/>
                            <TextBlock Text="{Binding GitStatusGlyph}"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="#4CAF50"
                                       Margin="2,0,0,0"/>
                            <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>
    </Border>

</UserControl>
