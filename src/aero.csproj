<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Suppress CS0618 (XAML partial class/member not seen by IDE analyzer).
         The Roslyn analyzer doesn't see compiler-generated .g.cs files, but MSBuild
         resolves them correctly. Actual builds have 0 errors. -->
    <NoWarn>$(NoWarn);CS0618</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Fody weaver configuration (auto-generated, must be tracked in source) -->
    <None Include="FodyWeavers.xml" />
    <!-- Theme preset JSON files — embedded so ThemeEngine can load them at runtime -->
    <EmbeddedResource Include="Assets\Themes\*.json" />
  </ItemGroup>

  <ItemGroup>
    <!-- Avalonia core (11.3 = latest stable 11.x) -->
    <PackageReference Include="Avalonia" Version="11.3.*" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.*" />
    <PackageReference Include="Avalonia.Themes.Simple" Version="11.3.*" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.*" />
    <PackageReference Include="Avalonia.Diagnostics" Version="11.3.*" Condition="'$(Configuration)' == 'Debug'" />

    <!-- Editor -->
    <PackageReference Include="Avalonia.AvaloniaEdit" Version="11.3.*" />
    <PackageReference Include="AvaloniaEdit.TextMate" Version="11.3.*" />
    <PackageReference Include="Dock.Serializer.Newtonsoft" Version="11.3.*" />
    <PackageReference Include="Dock.Serializer.SystemTextJson" Version="11.3.*" />
    <PackageReference Include="TextMateSharp.Grammars" Version="1.*" />

    <!-- UI -->
    <PackageReference Include="Dock.Avalonia" Version="11.3.*" />
    <PackageReference Include="Dock.Avalonia.Themes.Simple" Version="11.3.*" />
    <!-- DialogHost.Avalonia requires Avalonia >= 12.0.0 — incompatible with Avalonia 11.3.
         Phase 8.3 (Command Palette) will use a custom overlay instead (simple: Border + opacity + TextBox).
         See docs/phases/phase-8/8.3-command-palette/ -->
    <!-- Material.Icons.Avalonia paused — resolved in Phase 8.5: text glyphs for Phase 8.
         Revisit when upgrading to Avalonia 12. See docs/phases/phase-8/8.5-icon-decision/. -->

    <!-- MVVM -->
    <PackageReference Include="ReactiveUI" Version="20.*" />
    <PackageReference Include="ReactiveUI.Fody" Version="19.*" />
    <PackageReference Include="Avalonia.ReactiveUI" Version="11.3.*" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="9.*" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.*" />

    <!-- Infrastructure -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.*" />
    <PackageReference Include="CliWrap" Version="3.*" />
    <PackageReference Include="StreamJsonRpc" Version="2.*" />
    <PackageReference Include="FuzzySharp" Version="2.*" />

    <!-- Git (Phase 7) -->
    <PackageReference Include="LibGit2Sharp" Version="0.30.*" />
    <PackageReference Include="DiffPlex" Version="1.7.*" />
  </ItemGroup>

</Project>
