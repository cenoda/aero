<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Aero.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Phase 8.9 Design System token dictionaries.
                     Order matters: Spacing → CornerRadius → Borders → Shadows → Typography → Transitions -->
                <ResourceInclude Source="avares://aero/Styles/Spacing.axaml" />
                <ResourceInclude Source="avares://aero/Styles/CornerRadius.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Borders.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Shadows.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Typography.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Transitions.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://Avalonia.Themes.Simple/SimpleTheme.xaml" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Simple/AvaloniaEdit.xaml" />
        <!-- Material.Icons.Avalonia paused — see docs/phases/phase-2/TOFIX.md
             Round 3 R3.1. Will be re-added when the icon library decision is made. -->
    </Application.Styles>
</Application>
