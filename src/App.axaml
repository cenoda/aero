<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:Aero.Converters"
             x:Class="Aero.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Phase 8.9 Design System token dictionaries.
                     Order matters: Spacing → CornerRadius → Borders → Shadows → Typography → Transitions -->
                <ResourceInclude Source="avares://aero/Styles/Spacing.axaml" />
                <ResourceInclude Source="avares://aero/Styles/CornerRadius.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Borders.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Shadows.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Typography.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Transitions.axaml" />
                <ResourceInclude Source="avares://aero/Styles/Icons.axaml" />
                <!-- Phase 8.2: Theme presets loaded here; ThemeService identifies them via sentinel keys -->
                <ResourceInclude Source="avares://aero/Styles/ThemeLight.axaml" />
                <ResourceInclude Source="avares://aero/Styles/ThemeDark.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters (app-level) -->
            <converters:BoolToWindowStateConverter x:Key="BoolToWindowStateConverter"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://Avalonia.Themes.Simple/SimpleTheme.xaml" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Simple/AvaloniaEdit.xaml" />
        <!-- Phosphor Icons embedded via src/Styles/Icons.axaml (Phase 8.5).
             Material.Icons.Avalonia deferred to Avalonia 12 upgrade. -->
        <!-- Phase 8.9 Control Themes — layered after SimpleTheme so overrides win -->
        <StyleInclude Source="avares://aero/Styles/ControlThemes.axaml" />
    </Application.Styles>
</Application>
