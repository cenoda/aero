<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aero.ViewModels"
        x:Class="Aero.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="Aero"
        Width="1200"
        Height="800"
        MinWidth="600"
        MinHeight="400">

    <DockPanel>
        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusText}"
                   Margin="8,4" />

        <!-- Main content placeholder — replaced in Phase 1 -->
        <TextBlock Text="Aero"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.2" />
    </DockPanel>

</Window>
