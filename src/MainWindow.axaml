<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aero.ViewModels"
        xmlns:views="using:Aero.Views"
        x:Class="Aero.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="{Binding WindowTitle}"
        Width="{Binding WindowWidth}"
        Height="{Binding WindowHeight}"
        MinWidth="600"
        MinHeight="400"
        WindowState="{Binding IsWindowMaximized, Converter={StaticResource BoolToWindowStateConverter}}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FindCommand}"/>
        <KeyBinding Gesture="Ctrl+H" Command="{Binding ReplaceCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewFileCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding OpenFolderCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PreviousTabCommand}"/>
        <KeyBinding Gesture="Ctrl+F4" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Space" Command="{Binding EditorViewModel.CompletionCommand}"/>
        <KeyBinding Gesture="Ctrl+OemTilde" Command="{Binding ToggleOutputCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+B" Command="{Binding BuildCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding ToggleThemeCommand}"/>
    </Window.KeyBindings>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewFileCommand}" InputGesture="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O"/>
                <MenuItem Header="Open _Folder..." Command="{Binding OpenFolderCommand}" InputGesture="Ctrl+Shift+O"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGesture="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGesture="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Close" Command="{Binding CloseFileCommand}" InputGesture="Ctrl+W"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Find..." Command="{Binding FindCommand}" InputGesture="Ctrl+F"/>
                <MenuItem Header="_Replace..." Command="{Binding ReplaceCommand}" InputGesture="Ctrl+H"/>
            </MenuItem>
<MenuItem Header="_View">
                <MenuItem Header="Toggle _Sidebar" Command="{Binding ToggleSidebarCommand}"/>
                <MenuItem Header="Toggle _Git Panel" Command="{Binding ToggleSidebarTabCommand}"/>
                <MenuItem Header="Toggle _Output" Command="{Binding ToggleOutputCommand}"/>
                <MenuItem Header="Toggle _Problems" Command="{Binding ToggleProblemsCommand}"/>
                <MenuItem Header="Toggle _Bottom Panel" Command="{Binding ToggleBottomPanelCommand}"/>
            </MenuItem>
            <MenuItem Header="_Build">
                <MenuItem Header="_Build" Command="{Binding BuildCommand}" InputGesture="Ctrl+Shift+B"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Main editor area: sidebar | splitter | (editor + status bar) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar column: 0px when collapsed, SidebarWidth when visible -->
                <ColumnDefinition Width="{Binding SidebarColumnWidth}"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar (Phase 2 M2) -->
            <Border Grid.Column="0"
                    IsVisible="{Binding IsSidebarVisible}"
                    CornerRadius="8,8,0,0"
                    BorderBrush="{DynamicResource panel.border}"
                    BorderThickness="1"
                    Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{DynamicResource panel.headerBackground}"
                            BorderBrush="{DynamicResource panel.border}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Button Grid.Column="0"
                                    Command="{Binding ToggleSidebarCommand}"
                                    HorizontalAlignment="Right"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4"
                                    ToolTip.Tip="Collapse sidebar"
                                    Cursor="Hand">
                                <PathIcon Data="{StaticResource Icon.ChevronLeft}"
                                          Width="12" Height="12"
                                          Foreground="{DynamicResource panel.headerForeground}"/>
                            </Button>
                        </Grid>
                </Border>
                <TabControl Grid.Row="1"
                           SelectedIndex="{Binding ActiveSidebarTabIndex}">
                    <TabItem Header="Explorer">
                        <views:FileExplorerView DataContext="{Binding FileExplorerViewModel}"/>
                    </TabItem>
                    <TabItem Header="Git">
                        <views:GitPanelView DataContext="{Binding GitViewModel}"/>
                    </TabItem>
                </TabControl>
                </Grid>
            </Border>

            <!-- Draggable divider between sidebar and editor -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          IsVisible="{Binding IsSidebarVisible}"
                          Background="{DynamicResource panel.border}"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Editor + bottom panel + status bar -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Editor panel with tabs -->
                <views:EditorView Grid.Row="0"
                               DataContext="{Binding EditorViewModel}"/>

                <!-- Problems panel (Phase 4 M4) -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              Background="{DynamicResource panel.border}"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              IsVisible="{Binding IsBottomPanelVisible}"/>

                <!-- Bottom panel with TabControl (Problems + Output tabs) -->
                <!-- Wrap in a Grid so IsVisible binds against ShellViewModel (parent DataContext),
                     not child ViewModels. Use TabControl for Problems/Output tabs. -->
                <!-- Phase 8.1 M1: Bottom panel header with title + collapse button -->
                <!-- Phase 8.1 M2: Border with corner radius on top corners -->
                <!-- Phase 8.1 M3: Height animation for collapse/expand -->
                <Border Grid.Row="2"
                        IsVisible="{Binding IsBottomPanelVisible}"
                        Height="{Binding BottomPanelHeight}"
                        CornerRadius="0,0,8,8"
                        BorderBrush="{DynamicResource panel.border}"
                        BorderThickness="1,0,1,1">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Height"
                                              Duration="0:0:0.200"
                                              Easing="CubicEaseOut"/>
                        </Transitions>
                    </Border.Transitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="100" MaxHeight="300"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{DynamicResource panel.headerBackground}"
                                BorderBrush="{DynamicResource panel.border}"
                                BorderThickness="0,1,0,0"
                                Padding="12,4">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding ActiveBottomTabTitle}"
                                           Foreground="{DynamicResource panel.headerForeground}"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="2"
                                        Command="{Binding ToggleBottomPanelCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4"
                                        ToolTip.Tip="Collapse panel"
                                        Cursor="Hand">
                                    <PathIcon Data="{StaticResource Icon.ChevronDown}"
                                              Width="12" Height="12"
                                              Foreground="{DynamicResource panel.headerForeground}"/>
                                </Button>
                            </Grid>
                        </Border>
                        <TabControl Grid.Row="1"
                                   SelectedIndex="{Binding ActiveBottomTabIndex}"
                                   MinHeight="100"
                                   MaxHeight="300">
                            <TabItem Header="Problems">
                                <views:ProblemsView DataContext="{Binding ProblemsViewModel}"/>
                            </TabItem>
                            <TabItem Header="Output">
                                <views:OutputView DataContext="{Binding OutputViewModel}"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>

<!-- Status bar -->
                <Border Grid.Row="3"
                        Background="{DynamicResource panel.sectionBackground}"
                        BorderBrush="{DynamicResource panel.border}"
                        BorderThickness="0,1,0,0"
                        Padding="8,4">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                        <!-- Cursor position -->
                        <TextBlock Grid.Column="0"
                                  Text="{Binding EditorViewModel.CursorPosition}"
                                  Margin="0,0,16,0"/>

                        <!-- Language -->
                        <TextBlock Grid.Column="1"
                                  Text="{Binding EditorViewModel.Language}"
                                  Margin="0,0,16,0"/>

                        <!-- Branch (visible when Git repository is open) -->
                        <TextBlock Grid.Column="2"
                                  Text="{Binding GitViewModel.CurrentBranch}"
                                  Foreground="Green"
                                  FontWeight="SemiBold"
                                  Margin="0,0,16,0"
                                  IsVisible="{Binding GitViewModel.HasGitRepository}"/>

                        <!-- TODO(phase-3): Detect encoding from BOM/file analysis -->
                        <TextBlock Grid.Column="3"
                                  Text="UTF-8"
                                  Margin="0,0,16,0"/>

                        <!-- TODO(phase-3): Detect line ending from file content -->
                        <TextBlock Grid.Column="4"
                                  Text="Lf"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>

</Window>