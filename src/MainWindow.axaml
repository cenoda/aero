<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aero.ViewModels"
        xmlns:views="using:Aero.Views"
        x:Class="Aero.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="{Binding WindowTitle}"
        Width="1200"
        Height="800"
        MinWidth="600"
        MinHeight="400">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FindCommand}"/>
        <KeyBinding Gesture="Ctrl+H" Command="{Binding ReplaceCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewFileCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding OpenFolderCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PreviousTabCommand}"/>
        <KeyBinding Gesture="Ctrl+F4" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Space" Command="{Binding EditorViewModel.CompletionCommand}"/>
        <KeyBinding Gesture="Ctrl+OemTilde" Command="{Binding ToggleOutputCommand}"/>
    </Window.KeyBindings>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewFileCommand}" InputGesture="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O"/>
                <MenuItem Header="Open _Folder..." Command="{Binding OpenFolderCommand}" InputGesture="Ctrl+Shift+O"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGesture="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGesture="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Close" Command="{Binding CloseFileCommand}" InputGesture="Ctrl+W"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Find..." Command="{Binding FindCommand}" InputGesture="Ctrl+F"/>
                <MenuItem Header="_Replace..." Command="{Binding ReplaceCommand}" InputGesture="Ctrl+H"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _File Explorer" Command="{Binding ToggleFileExplorerCommand}"/>
                <MenuItem Header="Toggle _Output" Command="{Binding ToggleOutputCommand}"/>
                <MenuItem Header="Toggle _Problems" Command="{Binding ToggleProblemsCommand}"/>
                <MenuItem Header="Toggle _Bottom Panel" Command="{Binding ToggleBottomPanelCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Main editor area: sidebar | splitter | (editor + status bar) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar: fixed default width, MinWidth lets the user collapse to a sliver. -->
                <ColumnDefinition Width="250" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar (Phase 2 M2). Wrap in a Grid so IsVisible binds against ShellViewModel
                 (parent DataContext), not FileExplorerViewModel (child DataContext override). -->
            <Grid Grid.Column="0"
                  IsVisible="{Binding IsFileExplorerVisible}">
                <views:FileExplorerView DataContext="{Binding FileExplorerViewModel}"/>
            </Grid>

            <!-- Draggable divider between sidebar and editor -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          Background="#CCCCCC"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Editor + bottom panel + status bar -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Editor panel with tabs -->
                <views:EditorView Grid.Row="0"
                               DataContext="{Binding EditorViewModel}"/>

                <!-- Problems panel (Phase 4 M4) -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              Background="#CCCCCC"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              IsVisible="{Binding IsBottomPanelVisible}"/>

                <!-- Bottom panel with TabControl (Problems + Output tabs) -->
                <!-- Wrap in a Grid so IsVisible binds against ShellViewModel (parent DataContext),
                     not child ViewModels. Use TabControl for Problems/Output tabs. -->
                <TabControl Grid.Row="2"
                          SelectedIndex="{Binding ActiveBottomTabIndex}"
                          IsVisible="{Binding IsBottomPanelVisible}"
                          MinHeight="100"
                          MaxHeight="300">
                    <TabItem Header="Problems">
                        <views:ProblemsView DataContext="{Binding ProblemsViewModel}"/>
                    </TabItem>
                    <TabItem Header="Output">
                        <views:OutputView DataContext="{Binding OutputViewModel}"/>
                    </TabItem>
                </TabControl>

                <!-- Status bar -->
                <Border Grid.Row="3"
                        Background="#F0F0F0"
                        BorderBrush="#CCCCCC"
                        BorderThickness="0,1,0,0"
                        Padding="8,4">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                        <!-- Cursor position -->
                        <TextBlock Grid.Column="0"
                                  Text="{Binding EditorViewModel.CursorPosition}"
                                  Margin="0,0,16,0"/>

                        <!-- Language -->
                        <TextBlock Grid.Column="1"
                                  Text="{Binding EditorViewModel.Language}"
                                  Margin="0,0,16,0"/>

                        <!-- TODO(phase-3): Detect encoding from BOM/file analysis -->
                        <TextBlock Grid.Column="3"
                                  Text="UTF-8"
                                  Margin="0,0,16,0"/>

                        <!-- TODO(phase-3): Detect line ending from file content -->
                        <TextBlock Grid.Column="4"
                                  Text="Lf"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>

</Window>